</p>\r\n\r\n<div class=\"wrapper\" id=\"w\">\r\n  <img src=\"https://cdn.shopify.com/s/files/1/0935/6191/3693/files/gempages_556740947103187724-897743fb-625d-4e6b-9521-517e0d63744b.jpg?v=1755674861\" alt=\"Nachher\">\r\n  <div class=\"before-clip\" id=\"bc\">\r\n    <img src=\"https://cdn.shopify.com/s/files/1/0935/6191/3693/files/gempages_556740947103187724-c6c04519-0eb2-47b3-a2a8-f50ead043a81.jpg?v=1755674926\" alt=\"Vorher\">\r\n  </div>\r\n  <span class=\"lbl lbl-l\">Vorher</span>\r\n  <span class=\"lbl lbl-r\">Nachher</span>\r\n  <div class=\"dot\" id=\"dot\">|||</div>\r\n  <div class=\"touch-layer\" id=\"tl\"></div>\r\n</div>\r\n\r\n<script>\r\n  var bc = document.getElementById('bc');\r\n  var dot = document.getElementById('dot');\r\n  var tl = document.getElementById('tl');\r\n  var w = document.getElementById('w');\r\n\r\n  function setPos(pct) {\r\n    pct = Math.max(0, Math.min(100, pct));\r\n    bc.style.width = pct + '%';\r\n    dot.style.left = pct + '%';\r\n  }\r\n\r\n  tl.addEventListener('touchmove', function(e) {\r\n    var touch = e.touches[0];\r\n    var rect = w.getBoundingClientRect();\r\n    var pct = ((touch.clientX - rect.left) / rect.width) * 100;\r\n    setPos(pct);\r\n    e.preventDefault();\r\n  }, { passive: false });\r\n\r\n  tl.addEventListener('mousemove', function(e) {\r\n    if (e.buttons !== 1) return;\r\n    var rect = w.getBoundingClientRect();\r\n    var pct = ((e.clientX - rect.left) / rect.width) * 100;\r\n    setPos(pct);\r\n  });\r\n\r\n  setPos(50);\r\n</script>\r\n\r\n</body>\r\n</html>","type":"html","height":340,"isBulk":null,"layout":"webEmbed","script":null,"spacing":{"margin":null,"padding":null},"isPreviewing":null},{"key":"VBdjligtTjuAkMGCCf","items":[{"text":"Felgenreiniger sichern","width":271,"height":40,"navigator":{"key":"yPmqvSAvXz","product":"gid://shopify/Product/15233988755805"},"textColor":"FFFFFFFF","marginLeft":0,"marginRight":0,"useMaxWidth":false,"borderRadius":10,"textFontSize":17,"backgroundColor":"