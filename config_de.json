lse,"backgroundColor":null,"showDescription":false,"keepDefaultTitle":false,"productListAnimationConfig":null},{"tag":null,"name":null,"image":"https://raw.githubusercontent.com/fluxbuilder/images/main/2025/12/c2ac155b5537/1765527015594.webp","order":null,"title":"Lederpflege","colors":null,"onSale":false,"orderby":null,"category":"gid://shopify/Collection/650806165853","featured":false,"showText":true,"description":null,"productType":false,"originalColor":false,"backgroundColor":null,"showDescription":false,"keepDefaultTitle":false,"productListAnimationConfig":null},{"tag":null,"name":null,"image":"https://raw.githubusercontent.com/fluxbuilder/images/main/2025/12/c2ac155b5537/1765527044122.webp","order":null,"title":"Lackpflege","colors":null,"onSale":false,"orderby":null,"category":"gid://shopify/Collection/651661541725","featured":false,"showText":true,"description":null,"productType":false,"originalColor":false,"backgroundColor":null,"showDescription":false,"keepDefaultTitle":false,"productListAnimationConfig":null},{"tag":null,"name":null,"image":"https://raw.githubusercontent.com/fluxbuilder/images/main/2025/12/c2ac155b5537/1765527071754.webp","order":null,"title":"Kunststoff","colors":null,"onSale":false,"orderby":null,"category":"gid://shopify/Collection/650808131933","featured":false,"showText":true,"description":null,"productType":false,"originalColor":false,"backgroundColor":null,"showDescription":false,"keepDefaultTitle":false,"productListAnimationConfig":null},{"tag":null,"name":null,"image":"https://raw.githubusercontent.com/fluxbuilder/images/main/2025/12/c2ac155b5537/1765527112418.webp","order":null,"title":"Mikrofaser","colors":null,"onSale":false,"orderby":null,"category":"","featured":false,"showText":true,"description":null,"productType":false,"originalColor":false,"backgroundColor":null,"showDescription":false,"keepDefaultTitle":false,"productListAnimationConfig":null}],"border":0.6,"isBulk":null,"layout":"category","radius":150,"shadow":null,"columns":null,"marginX":0,"marginY":0,"spacing":12,"itemSize":{"width":100,"height":131},"paddingX":10,"paddingY":10,"hideTitle":false,"marginTop":0,"marginLeft":0,"imageBoxFit":"cover","marginRight":0,"enableBorder":false,"imageSpacing":0,"isPreviewing":null,"marginBottom":0,"noBackground":false,"gradientStyle":false,"labelFontSize":12,"originalColor":false,"separateWidth":24,"textAlignment":"topCenter","horizontalItem":false,"animationConfig":null,"enableBackground":null,"imageBorderColor":"FF000000","imageBorderStyle":"solid","imageBorderWidth":1.1,"categoryMenuShowDepth":false,"productCategoryMenuStyle":"menu","allowFilterMultipleCategory":false},{"key":"xbRUZvOWTCWJk","data":"<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Car Care Marquee Style</title>\n    <style>\n        /* --- GRUNDGERÜST --- */\n        body {\n            margin: 0;\n            padding: 0;\n            background-color: #ffffff;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: auto;\n            font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n            overflow: hidden;\n        }\n\n        /* --- MARQUEE CONTAINER --- */\n        .marquee-wrapper {\n            width: 100%;\n            overflow: hidden;\n            white-space: nowrap;\n            position: relative;\n            padding: 20px 0;\n        }\n\n        .marquee-track {\n            display: inline-flex;\n            gap: 4rem;\n            animation: scroll-left 25s linear infinite;\n            padding-right: 4rem;\n        }\n\n        /* --- TEXT STYLING --- */\n        .marquee-item {\n            display: flex;\n            align-items: center;\n            font-size: 1.5rem;\n            color: #1a1a1a;\n            font-weight: 500;\n        }\n\n        /* --- DER \"HELLE\" KEYWORD STYLE (OUTLINE) --- */\n        .outline-text {\n            color: transparent;\n            -webkit-text-stroke: 1px #ccc;\n            font-weight: 700;\n            margin: 0 4px;\n        }\n\n        /* --- ICON STYLING (SVG) --- */\n        .icon {\n            width: 24px;\n            height: 24px;\n            margin-right: 12px;\n            stroke: #1a1a1a;\n            stroke-width: 2;\n            fill: none;\n            position: relative;\n            top: -2px;\n        }\n\n        /* --- ANIMATION --- */\n        @keyframes scroll-left {\n            0% { transform: translateX(0); }\n            100% { transform: translateX(-50%); }\n        }\n\n        /* Handy-Anpassung */\n        @media (max-width: 600px) {\n            .marquee-item { font-size: 1.1rem; }\n            .icon { width: 18px; height: 18px; }\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"marquee-wrapper\">\n        <div class=\"marquee-track\">\n            \n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"></path></svg>\n                <span class=\"outline-text\">Car Care</span> ist Lifestyle – nicht nur Pflicht\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg>\n                <span class=\"outline-text\">Für alle</span>, die ihr <span class=\"outline-text\">Auto</span> wirklich lieben\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"></polygon></svg>\n                Glanz, Schutz & Pflege – <span class=\"outline-text\">Made in Germany</span>\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"></path></svg>\n                Dein <span class=\"outline-text\">Auto</span> braucht Liebe\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"></path></svg>\n                <span class=\"outline-text\">Car Care</span> ist Lifestyle – nicht nur Pflicht\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg>\n                <span class=\"outline-text\">Für alle</span>, die ihr <span class=\"outline-text\">Auto</span> wirklich lieben\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"></polygon></svg>\n                Glanz, Schutz & Pflege – <span class=\"outline-text\">Made in Germany</span>\n            </div>\n\n            <div class=\"marquee-item\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"></path></svg>\n                Dein <span class=\"outline-text\">Auto</span> braucht Liebe\n            </div>\n\n        </div>\n    </div>\n\n</body>\n</html>","type":"html","height":51,"isBulk":null,"layout":"webEmbed","script":null,"spacing":{"margin":null,"padding":null},"isPreviewing":null},{"key":"yqhwxsdCFQynPU","data":"<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<style>\n  html, body {\n    margin: 0;\n    padding: 0;\n    height: 200px;\n    touch-action: pan-y !important;\n    -webkit-overflow-scrolling: touch;\n    overscroll-behavior: contain;\n  }\n  .slider-container {\n    width: 100%;\n    overflow: hidden;\n    background: transparent;\n    padding: 10px 0;\n    height: 200px;\n    touch-action: pan-y !important;\n    pointer-events: none; /* lässt Touches zur App durch */\n  }\n  .slider-track {\n    display: flex;\n    gap: 12px;\n    width: max-content;\n    animation: scroll 15s linear infinite;\n    touch-action: pan-y !important;\n    pointer-events: none;\n  }\n  @keyframes scroll {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .slide {\n    width: 120px;\n    height: 180px;\n    border-radius: 16px;\n    overflow: hidden;\n    flex-shrink: 0;\n    box-shadow: 0 4px 6px rgba(0,0,0,0.15);\n    pointer-events: none;\n  }\n  .slide img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    pointer-events: none;\n    -webkit-user-drag: none;\n  }\n</style>\n</head>\n<body>\n<div class=\"slider-container\">\n  <div class=\"slider-track\">\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/sprueh_innenraumreiniger.webp?v=1763550178&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/IMG_0491.webp?v=1763550278&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/IMG_0088.webp?v=1763550312&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/gempages_556740947103187724-f7356cf5-ee07-4c73-9e42-b978d98be287.webp?v=1763550152&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/beide.webp?v=1753354253&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/Flugrostflasche.webp?v=1753355745&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/IMG_0473.webp?v=1755598118&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/sprueh_innenraumreiniger.webp?v=1763550178&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/IMG_0491.webp?v=1763550278&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/IMG_0088.webp?v=1763550312&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/gempages_556740947103187724-f7356cf5-ee07-4c73-9e42-b978d98be287.webp?v=1763550152&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/beide.webp?v=1753354253&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/Flugrostflasche.webp?v=1753355745&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/IMG_0473.webp?v=1755598118&width=600\"></div>\n    <div class=\"slide\"><img src=\"https://www.viscuragermany.de/cdn/shop/files/sprueh_innenraumreiniger.webp?v=1763550178&width=600\"></div>\n  </div>\n</div>\n</body>\n</html>","type":"html","height":220,"isBulk":null,"layout":"webEmbed","script":"","spacing":{"margin":null,"padding":null},"isPreviewing":null},{"key":"svXtHyFeofDuaTG","data":"<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Viscura Auto-Scroll Reviews</title>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif; }\n\n  body {\n    overflow: hidden;\n    height: auto;\n  }\n\n  .review-section {\n    max-width: 100%;\n    margin: 40px 0;\n    user-select: none; \n  }\n\n  .review-header {\n    padding: 0 20px;\n    margin-bottom: 20px;\n    display: flex; justify-content: space-between; align-items: end;\n  }\n\n  .review-title { font-size: 1.4rem; font-weight: 700; color: #000; }\n  .review-subtitle { font-size: 0.9rem; color: #666; margin-top: 5px; }\n\n  .review-track {\n    display: flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory; \n    -webkit-overflow-scrolling: touch; \n    padding: 10px 20px 30px 20px;\n    scrollbar-width: none; \n    cursor: grab;\n    scroll-behavior: smooth; \n  }\n\n  .review-track.active {\n    cursor: grabbing;\n    scroll-snap-type: none;\n    scroll-behavior: auto;\n  }\n  \n  .review-track::-webkit-scrollbar { display: none; }\n\n  .review-card {\n    position: relative;\n    flex: 0 0 320px; \n    background: #141414; \n    border: 1px solid #333;\n    border-radius: 24px;\n    padding: 24px;\n    scroll-snap-align: center;\n    display: flex; flex-direction: column; justify-content: space-between;\n    box-shadow: 0 8px 20px rgba(0,0,0,0.3);\n    color: #fff;\n    -webkit-user-drag: none; \n  }\n\n  .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }\n  .stars { color: #772541; letter-spacing: 2px; font-size: 14px; }\n  .date { font-size: 12px; color: #666; }\n\n  .review-title-text { font-weight: 700; font-size: 1.1rem; margin-bottom: 8px; line-height: 1.3; color: #fff; }\n  \n  .review-body {\n    font-size: 0.95rem; color: #ccc; line-height: 1.5; margin-bottom: 20px;\n    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;\n  }\n\n  .author-row {\n    display: flex; align-items: center; gap: 12px; margin-top: auto;\n    border-top: 1px solid #333; padding-top: 15px;\n  }\n  .avatar {\n    width: 40px; height: 40px; background: #333; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-weight: bold; font-size: 14px; color: #fff;\n  }\n  .author-info { display: flex; flex-direction: column; }\n  .author-name { font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 6px; color: #fff; }\n  \n  .verified-badge {\n    width: 14px; height: 14px; background: #772541; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .verified-badge::after { content: '✓'; font-size: 9px; color: white; }\n  .used-product { font-size: 11px; color: #888; margin-top: 2px; }\n\n  @media (max-width: 768px) {\n    .review-card { flex: 0 0 85vw; } \n  }\n</style>\n</head>\n<body>\n\n<div class=\"review-section\">\n  \n  <div class=\"review-header\">\n    <div>\n      <div class=\"review-title\">Echte Ergebnisse</div>\n      <div class=\"review-subtitle\">Basierend auf 20.000+ Kunden</div>\n    </div>\n    <div style=\"font-size: 18px; color: #772541; font-weight:bold;\">★ 4.8</div>\n  </div>\n\n  <div class=\"review-track\" id=\"reviewTrack\">\n\n    <div class=\"review-card\">\n      <div class=\"card-top\"><div class=\"stars\">★★★★★</div><div class=\"date\">vor 2 Tagen</div></div>\n      <div class=\"review-title-text\">Schneller Schutz, toller Effekt</div>\n      <div class=\"review-body\">\"Die Sprühversiegelung spart mir extrem viel Zeit. Das Wasser perlt sofort ab und der Glanz ist unglaublich.\"</div>\n      <div class=\"author-row\">\n        <div class=\"avatar\">MA</div> \n        <div class=\"author-info\"><div class=\"author-name\">Mehmet A. <div class=\"verified-badge\"></div></div><div class=\"used-product\">Nutzt: Wax Shampoo</div></div>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"card-top\"><div class=\"stars\">★★★★★</div><div class=\"date\">vor 5 Tagen</div></div>\n      <div class=\"review-title-text\">Endlich saubere Felgen</div>\n      <div class=\"review-body\">\"Habe schon vieles probiert, aber der Felgenreiniger von Viscura ist eine andere Liga. Aufsprühen, warten, abspülen.\"</div>\n      <div class=\"author-row\">\n        <div class=\"avatar\" style=\"background: linear-gradient(45deg, #1e3c72, #2a5298);\">TK</div>\n        <div class=\"author-info\"><div class=\"author-name\">Thomas K. <div class=\"verified-badge\"></div></div><div class=\"used-product\">Nutzt: Felgenreiniger</div></div>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"card-top\"><div class=\"stars\">★★★★★</div><div class=\"date\">vor 1 Woche</div></div>\n      <div class=\"review-title-text\">Premium Qualität</div>\n      <div class=\"review-body\">\"Lieferung war am nächsten Tag da. Die Verpackung ist sehr hochwertig und das Innenraumspray riecht extrem angenehm.\"</div>\n      <div class=\"author-row\">\n        <div class=\"avatar\" style=\"background: #333;\">LS</div>\n        <div class=\"author-info\"><div class=\"author-name\">Lisa S. <div class=\"verified-badge\"></div></div><div class=\"used-product\">Nutzt: Innenraumpflege</div></div>\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"card-top\"><div class=\"stars\">★★★★★</div><div class=\"date\">vor 2 Wochen</div></div>\n      <div class=\"review-title-text\">Bester Reiniger bisher</div>\n      <div class=\"review-body\">\"Ich wasche mein Auto sehr oft und bin sehr pingelig. Viscura hat mich aber absolut überzeugt. Preis-Leistung stimmt hier einfach.\"</div>\n      <div class=\"author-row\">\n        <div class=\"avatar\">DN</div>\n        <div class=\"author-info\"><div class=\"author-name\">Dennis N. <div class=\"verified-badge\"></div></div><div class=\"used-product\">Nutzt: Komplett-Set</div></div>\n      </div>\n    </div>\n    \n    <div class=\"review-card\">\n      <div class=\"card-top\"><div class=\"stars\">★★★★★</div><div class=\"date\">Gestern</div></div>\n      <div class=\"review-title-text\">Alles perfekt</div>\n      <div class=\"review-body\">\"Schneller Versand und das Ergebnis kann sich sehen lassen. Gerne wieder!\"</div>\n      <div class=\"author-row\">\n        <div class=\"avatar\">SR</div>\n        <div class=\"author-info\"><div class=\"author-name\">Stefan R. <div class=\"verified-badge\"></div></div><div class=\"used-product\">Nutzt: Außenreiniger</div></div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  const revSlider = document.getElementById('reviewTrack');\n  \n  let autoScrollInterval;\n  const SCROLL_DELAY = 3000;\n\n  function startAutoScroll() {\n    autoScrollInterval = setInterval(() => {\n      const card = revSlider.querySelector('.review-card');\n      const cardWidth = card.offsetWidth + 16;\n      \n      if (revSlider.scrollLeft + revSlider.clientWidth >= revSlider.scrollWidth - 10) {\n        revSlider.scrollTo({ left: 0, behavior: 'smooth' });\n      } else {\n        revSlider.scrollBy({ left: cardWidth, behavior: 'smooth' });\n      }\n    }, SCROLL_DELAY);\n  }\n\n  function stopAutoScroll() {\n    clearInterval(autoScrollInterval);\n  }\n\n  startAutoScroll();\n\n  revSlider.addEventListener('mouseenter', stopAutoScroll);\n  revSlider.addEventListener('mouseleave', startAutoScroll);\n  revSlider.addEventListener('touchstart', stopAutoScroll);\n  revSlider.addEventListener('touchend', startAutoScroll);\n\n  let isRevDown = false;\n  let startRevX;\n  let scrollRevLeft;\n\n  revSlider.addEventListener('mousedown', (e) => {\n    stopAutoScroll();\n    isRevDown = true;\n    revSlider.classList.add('active');\n    startRevX = e.pageX - revSlider.offsetLeft;\n    scrollRevLeft = revSlider.scrollLeft;\n  });\n\n  revSlider.addEventListener('mouseup', () => { \n    isRevDown = false; \n    revSlider.classList.remove('active'); \n    startAutoScroll();\n  });\n  \n  revSlider.addEventListener('mouseleave', () => { \n    isRevDown = false; \n    revSlider.classList.remove('active'); \n  });\n\n  revSlider.addEventListener('mousemove', (e) => {\n    if (!isRevDown) return;\n    e.preventDefault();\n    const x = e.pageX - revSlider.offsetLeft;\n    const walk = (x - startRevX) * 2;\n    revSlider.scrollLeft = scrollRevLeft - walk;\n  });\n</script>\n\n</body>\n</html>","type":"html","height":478,"isBulk":null,"layout":"webEmbed","script":"","spacing":{"margin":null,"padding":null},"isPreviewing":null},{"key":"ALkNavQkbp","name":"Bestseller","rows":1,"isBulk":null,"layout":"threeColumn","onSale":false,"columns":0,"hMargin":6,"useSort":false,"vMargin":0,"category":"gid://shopify/Collection/666153550173","featured":false,"hPadding":0,"parallax":false,"vPadding":0,"hidePrice":false,"hideStore":false,"hideTitle":false,"showHeart":true,"titleLine":2,"cardDesign":"card","imageRatio":0.9,"isSnapping":false,"hideAddress":false,"imageBoxfit":"cover","borderRadius":3,"enableRating":true,"isPreviewing":null,"showCartIcon":false,"showCategory":false,"showQuantity":false,"showCountDown":false,"showOnlyImage":false,"advancedParams":{},"cartIconRadius":9,"showCartButton":true,"showListingType":true,"showPhoneNumber":false,"showStockStatus":true,"backgroundHeight":373,"backgroundRadius":10,"enableAutoSliding":false,"showCartIconColor":false,"useCircularRadius":true,"parallaxImageRatio":1.2,"showShortDescription":false,"enableBottomAddToCart":false,"productListItemHeight":126,"cartButtonQuantitySize":40,"hideEmptyProductLayout":false,"showProductCardCategory":false,"hideEmptyProductListRating":false,"showCartButtonWithQuantity":false},{"key":"mriwaMdEQt","data":"<!DOCTYPE html>\r\n<html>\r\n<head>\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\r\n<style>\r\